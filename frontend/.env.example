# ============================================================
# Frontend 服务配置
# - 容器化：被 compose 通过 env_file 注入到 aichatbot-frontend 容器
# - Vite dev server 启动时也会读本文件（仅 VITE_ 前缀变量会暴露给 client）
# ============================================================

# ----- 联调开关（默认均为 mock，与 Phase 2 行为一致）-----
# SSE：设为 false 时走真实 POST /chat/stream（需已登录且 Vite 代理指向后端）
VITE_USE_MOCK_SSE=true
# 会话列表：true 强制只用本地 seed；false 强制 GET /sessions；未设置则与 mock token 联动
# VITE_USE_MOCK_SESSIONS=true

# /api 反向代理目标。容器化下指向 backend 服务名；本地直跑请改 http://localhost:8001
VITE_PROXY_TARGET=http://backend:8000

# ----- 容器内 HMR 文件监听（virtio-fs 不支持 inotify，需要轮询）-----
CHOKIDAR_USEPOLLING=true
WATCHPACK_POLLING=true
