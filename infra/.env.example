# ============================================================
# 编排层 / 基础设施配置（infra）
# 仅供 podman-compose 使用：
#   1) podman-compose --env-file infra/.env 做 ${...} 插值
#   2) postgres 容器初始化（POSTGRES_*、APP_DB_PASSWORD、BIZ_RO_PASSWORD）
#   3) 宿主机端口映射（BACKEND_PORT / FRONTEND_PORT）
# 不会被注入到 backend / frontend 容器（它们各自读自己目录下的 .env）
# ============================================================

# ----- Postgres 容器 -----
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=aichatbot
POSTGRES_PORT=5432

# 应用账号（init-roles.sh 创建；同时被 compose 注入 backend 拼连接串）
APP_DB_PASSWORD=app_pwd_change_me

# 业务库只读账号（执行 LLM 生成的 SQL；强制只读）
BIZ_RO_PASSWORD=biz_ro_pwd_change_me

# ----- 宿主机端口映射 -----
# 本机 8000/5173 已被其他项目占用时，可换成 8001/5174
BACKEND_PORT=8001
FRONTEND_PORT=5174
