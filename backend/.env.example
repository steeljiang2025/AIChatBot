# ============================================================
# Backend 服务配置
# - 容器化：被 compose 通过 env_file 注入到 aichatbot-backend 容器
# - 本地直跑：被 pydantic-settings 直接从本文件读取
# 数据库连接串（META_DB_URL / BIZ_DB_URL）由 compose 在 environment
# 中用 infra/.env 的 ${...} 拼装，避免在两处冗余维护密码
# ============================================================

# ----- 应用 -----
APP_ENV=dev
APP_LOG_LEVEL=INFO
APP_NAME=AIChatBot
APP_VERSION=0.1.0

# ----- CORS（与前端 dev 端口对齐；多值逗号分隔）-----
CORS_ORIGINS=http://localhost:5174,http://127.0.0.1:5174,http://localhost:5173,http://127.0.0.1:5173

# ----- JWT（Phase 3 起使用）-----
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=120

# ----- LLM（阿里云百炼 OpenAI 兼容；Phase 3 起使用）-----
DASHSCOPE_API_KEY=sk-your-dashscope-key
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_CHAT_MODEL=qwen3-max
QWEN_EMBEDDING_MODEL=text-embedding-v4
QWEN_EMBEDDING_DIM=1024

# ----- 数据库（仅本地直跑时填；容器模式由 compose 注入，留空即可）-----
# META_DB_URL=postgresql+psycopg://app_user:app_pwd_change_me@localhost:5432/aichatbot
# BIZ_DB_URL=postgresql+psycopg://biz_ro:biz_ro_pwd_change_me@localhost:5432/aichatbot
